# Database
# Use a least-privilege runtime role for DATABASE_URL.
# Keep DIRECT_URL on a higher-privilege admin role for Prisma schema changes.
DATABASE_URL="postgresql://user:password@host:5432/f10_fantasy"
DIRECT_URL="postgresql://postgres:password@host:5432/postgres"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
ACCOUNT_TOKEN_ENCRYPTION_KEY=""

# Google OAuth (required)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (optional)
APPLE_ID=""
APPLE_SECRET=""

# Cron job auth
CRON_SECRET="your-secret-token"

# F1 data provider (defaults to https://api.openf1.org/v1)
OPENF1_BASE_URL="https://api.openf1.org/v1"
