generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String          @id @default(cuid())
  name                String?
  email               String          @unique
  emailVerified       DateTime?
  image               String?
  publicUsername      String?         @unique
  usernameSet         Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  favoriteTeamSlug    String?
  usernameChangeUsed  Boolean         @default(false)
  tutorialDismissedAt DateTime?
  sessionValidAfter   DateTime        @default(now())
  accounts            Account[]
  receivedRequests    FriendRequest[] @relation("ReceivedRequests")
  sentRequests        FriendRequest[] @relation("SentRequests")
  pickSets            PickSet[]
  sessions            Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Season {
  id       String  @id @default(cuid())
  year     Int     @unique
  isActive Boolean @default(false)
  races    Race[]
}

model Race {
  id                         String             @id @default(cuid())
  seasonId                   String
  round                      Int
  name                       String
  circuitName                String
  country                    String
  type                       RaceType           @default(MAIN)
  scheduledStartUtc          DateTime
  lockCutoffUtc              DateTime
  status                     RaceStatus         @default(UPCOMING)
  openf1SessionKey           Int?               @unique
  openf1QualifyingSessionKey Int?               @unique
  openf1MeetingKey           Int?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  pickSets                   PickSet[]
  season                     Season             @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  entries                    RaceEntry[]
  results                    RaceResult[]
  qualifyingResults          QualifyingResult[]

  @@unique([seasonId, round, type])
}

model Constructor {
  id             String   @id @default(cuid())
  name           String
  shortName      String
  color          String
  openf1TeamName String?  @unique
  drivers        Driver[]
}

model Driver {
  id                 String             @id @default(cuid())
  code               String
  firstName          String
  lastName           String
  number             Int
  photoUrl           String?
  constructorId      String
  openf1DriverNumber Int?               @unique
  constructor        Constructor        @relation(fields: [constructorId], references: [id])
  dnfPicks           PickSet[]          @relation("DnfPicks")
  tenthPicks         PickSet[]          @relation("TenthPlacePicks")
  winnerPicks        PickSet[]          @relation("WinnerPicks")
  entries            RaceEntry[]
  results            RaceResult[]
  qualifyingResults  QualifyingResult[]
}

model RaceEntry {
  id            String  @id @default(cuid())
  raceId        String
  driverId      String
  isEligibleDnf Boolean @default(true)
  driver        Driver  @relation(fields: [driverId], references: [id])
  race          Race    @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@unique([raceId, driverId])
}

model RaceResult {
  id         String       @id @default(cuid())
  raceId     String
  driverId   String
  position   Int?
  status     ResultStatus
  fastestLap Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  driver     Driver       @relation(fields: [driverId], references: [id])
  race       Race         @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@unique([raceId, driverId])
}

model QualifyingResult {
  id        String   @id @default(cuid())
  raceId    String
  driverId  String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  driver    Driver   @relation(fields: [driverId], references: [id])
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@unique([raceId, driverId])
  @@index([raceId, position])
}

model PickSet {
  id                 String          @id @default(cuid())
  userId             String
  raceId             String
  tenthPlaceDriverId String
  winnerDriverId     String
  dnfDriverId        String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  lockedAt           DateTime?
  dnfSeatKey         String?
  tenthPlaceSeatKey  String?
  winnerSeatKey      String?
  dnfDriver          Driver          @relation("DnfPicks", fields: [dnfDriverId], references: [id])
  race               Race            @relation(fields: [raceId], references: [id], onDelete: Cascade)
  tenthPlaceDriver   Driver          @relation("TenthPlacePicks", fields: [tenthPlaceDriverId], references: [id])
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  winnerDriver       Driver          @relation("WinnerPicks", fields: [winnerDriverId], references: [id])
  scoreBreakdown     ScoreBreakdown?

  @@unique([userId, raceId])
}

model ScoreBreakdown {
  id              String   @id @default(cuid())
  pickSetId       String   @unique
  tenthPlaceScore Int
  winnerBonus     Int
  dnfBonus        Int
  totalScore      Int
  computedAt      DateTime @default(now())
  pickSet         PickSet  @relation(fields: [pickSetId], references: [id], onDelete: Cascade)
}

model FriendRequest {
  id          String              @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  addressee   User                @relation("ReceivedRequests", fields: [addresseeId], references: [id], onDelete: Cascade)
  requester   User                @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

enum RaceType {
  MAIN
  SPRINT
}

enum RaceStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum ResultStatus {
  CLASSIFIED
  DNF
  DNS
  DSQ
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}
